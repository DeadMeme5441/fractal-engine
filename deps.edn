{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "1.12.4"}
        ;; cheshire backs the CLI's --json/--jsonl. It already arrives transitively
        ;; via the SDK; pinned explicitly so the uberjar bundles it deterministically.
        cheshire/cheshire {:mvn/version "5.13.0"}
        net.clojars.deadmeme5441/clojure-llm-sdk {:mvn/version "0.1.0"}}
 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1"
                 :git/sha "dfb30dd"}}
   :main-opts ["-m" "cognitect.test-runner"]}

  ;; Uberjar build for the `fractal` CLI (the agent use surface). The CLI carries
  ;; none of the TUI's fulcro deps — just base + cheshire. Native-image is OUT
  ;; (runtime eval), so we ship an uberjar:  clojure -T:build uber
  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.5"}}
   :ns-default build}

  ;; Evaluation harness — an EXTERNAL CONSUMER of the engine, never part of it.
  ;; Lives entirely under evals/; the :build alias above only sees ["src"], so the
  ;; harness can never leak into the shipped uberjar. It imports the engine's public
  ;; seams (process/run-task!, provider/complete, artifacts) and adds nothing to the
  ;; core surface. Run:  clojure -M:evals run --help
  :evals
  {:extra-paths ["evals/src" "evals/resources"]
   :main-opts ["-m" "fractal-eval.core"]}

  ;; Harness tests (offline, scripted provider — no keys, no spend):
  ;;   clojure -M:evals-test
  :evals-test
  {:extra-paths ["evals/src" "evals/resources" "evals/test"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
   :main-opts ["-m" "cognitect.test-runner" "-d" "evals/test"]}

  ;; Publish the thin library jar to Clojars. Reads CLOJARS_USERNAME /
  ;; CLOJARS_PASSWORD (a Clojars deploy token) from the environment. Build
  ;; first, then deploy:
  ;;   clojure -T:build jar
  ;;   clojure -X:deploy :artifact '"target/fractal-engine-0.1.1.jar"'
  ;; CI does both on a v* tag (see .github/workflows/release.yml), alongside
  ;; the uberjar GitHub release.
  :deploy
  {:replace-deps {slipset/deps-deploy {:mvn/version "0.2.2"}}
   :exec-fn deps-deploy.deps-deploy/deploy
   :exec-args {:installer :remote
               :sign-releases? false
               ;; b/write-pom emits the pom under the class-dir, not the repo
               ;; root where deps-deploy looks by default.
               :pom-file "target/classes/META-INF/maven/net.clojars.deadmeme5441/fractal-engine/pom.xml"
               :artifact "target/fractal-engine-0.1.1.jar"}}}}
